module Objects

/// Raw input property extracted from a generator tool's Pydantic input schema.
class ToolInputProperty {
  name: String(this.length > 0)
  schemaType: String(this.length > 0)
  required: Boolean
  defaultValue: String?
}

/// Raw generator tool facts. No process semantics live here.
class ToolRequirement {
  toolName: String(this.length > 0)
  title: String(this.length > 0)
  inputModel: String(this.length > 0)
  requiredInputFields: Listing<String>
  inputProperties: Listing<ToolInputProperty>
}

/// Human-behavior profile for a synthetic actor.
class RealismProfile {
  workerType: String(this.length > 0)
  workingHoursDeviation: Float
  pauseCharacteristicsIndex: Int
}

/// Hard bounds used to validate LLM-generated actor realism.
class RealismGuardrails {
  delayMultiplierMin: Float(this > 0) = 0.5
  delayMultiplierMax: Float(this >= delayMultiplierMin) = 3.0
  workdayDeviationHoursMin: Float = -1.0
  workdayDeviationHoursMax: Float(this >= workdayDeviationHoursMin) = 1.0
  pauseDurationMinutesMin: Int(this >= 0) = 30
  pauseDurationMinutesMax: Int(this >= pauseDurationMinutesMin) = 75
  runtimeDelayCapSecondsMin: Float(this >= 0) = 0.5
  runtimeDelayCapSecondsMax: Float(this >= runtimeDelayCapSecondsMin) = 10.0
}

/// Inclusive minute range sampled by the trace generator.
class MinuteRange {
  min: Int(this >= 0)
  max: Int(this >= min)
}

/// Core workday and pause settings used for synthetic timestamp planning.
class WorkingHoursConfig {
  coreStart: String(this.length > 0) = "08:00"
  coreEnd: String(this.length > 0) = "17:00"
  dailyDeviationHoursMin: Float = -1.0
  dailyDeviationHoursMax: Float(this >= dailyDeviationHoursMin) = 1.0
  pauseWindowStart: String(this.length > 0) = "12:00"
  pauseWindowEnd: String(this.length > 0) = "13:30"
  pauseDurationMinutesMin: Int(this >= 0) = 30
  pauseDurationMinutesMax: Int(this >= pauseDurationMinutesMin) = 75
}

/// LLM realism compiler settings. Disabled keeps trace generation deterministic without LLM calls.
class RealismCompilerSettings {
  enabled: Boolean = false
  maxRetries: Int(this >= 1) = 3
  cacheDir: String(this.length > 0) = "configuration/build"
  dailyCaseCountMin: Int(this >= 0) = 0
  dailyCaseCountMax: Int(this >= dailyCaseCountMin) = 10000
  maxPriceVariationPct: Float(this >= 0) = 0.05
  maxDailyPriceTrendPct: Float(this >= 0) = 0.01
  maxWorkloadDelayMultiplierBoost: Float(this >= 0) = 0.25
  maxWorkloadWorkdayDeviationHoursBoost: Float(this >= 0) = 0.5
  relativeDemandWeightMin: Int(this >= 1) = 1
  relativeDemandWeightMax: Int(this >= relativeDemandWeightMin) = 100
  quantityVariationPctMin: Float(this >= 0) = 0.05
  quantityVariationPctMax: Float(this >= quantityVariationPctMin) = 0.5
  maxBulkOrderShare: Float(this >= 0 && this <= 1) = 0.35
  allowedOrderMultiples: Listing<Int(this >= 1)> = new Listing { 1; 5; 10; 20; 25; 50 }
  maxMaterialSharePerHorizon: Float(this > 0 && this <= 1)? = null
  requireAllActiveMaterialsInDemandProfile: Boolean = true
  materialValuationLockEnabled: Boolean = true
  materialValuationLockBufferSeconds: Int(this >= 0) = 120
  blockedMaterials: Listing<String(this.length > 0)> = new Listing {}
}

/// Waiting-time range between two process steps.
class InterStepDelayRange {
  fromStepType: String(this.length > 0)
  toStepType: String(this.length > 0)
  min: Int(this >= 0)
  max: Int(this >= min)
}

/// Declarative note for how one tool input is bound by the trace generator.
class ToolInputBinding {
  field: String(this.length > 0)
  source: String(
    this == "literal"
      || this == "master_data"
      || this == "case"
      || this == "planned_date"
      || this == "prior_output"
      || this == "derived",
  )
  value: String(this.length > 0)
  valueType: String(
    this == "string"
      || this == "int"
      || this == "float"
      || this == "bool",
  ) = "string"
}

/// Logical SAP export group the post processor should expect for reconciliation.
class PostProcessingExportGroup {
  id: String(this.length > 0)
  description: String(this.length > 0)
}

/// Explicit work capability for one synthetic actor.
class ActorCapability {
  processType: String(this.length > 0)
  stepTypes: Listing<String>
}

/// Synthetic business actor used by the trace generator.
class SyntheticActor {
  id: String(this.length > 0)
  displayName: String(this.length > 0)
  role: String(this.length > 0)
  timezone: String(this.length > 0)
  workLocation: String(this.length > 0)
  personaDescription: String
  delayMultiplier: Float(this > 0)
  runtimeDelayCapSeconds: Float(this >= 0)
  realismProfile: RealismProfile
  realismGuardrails: RealismGuardrails = new RealismGuardrails {}
  exposeInFinalDatasetAs: String(this.length > 0)
  capabilities: Listing<ActorCapability>
}

/// Technical SAP account reference. Values are environment variable names, not secrets themselves.
class TechnicalUser {
  id: String(this.length > 0)
  usernameEnvVar: String(this.length > 0)
  passwordEnvVar: String(this.length > 0)
  loginUrlEnvVar: String(this.length > 0)
  maxConcurrentActorSessions: Int(this >= 1) = 1
}

/// Mapping between synthetic actor and real technical SAP user.
class IdentityMapping {
  syntheticActorId: String(this.length > 0)
  technicalSapUserId: String(this.length > 0)
}

/// One configured process step. Assignment to a generator tool happens in Pkl.
class ProcessStep {
  stepId: String(this.length > 0)
  stepType: String(this.length > 0)
  tool: ToolRequirement?
  inputBindings: Listing<ToolInputBinding> = new Listing {}
  plannedDateInputBindings: Listing<ToolInputBinding> = new Listing {}
  requiredSapObjectKeys: Listing<String> = new Listing {}
}

/// Directed dependency between two configured process step types.
class ProcessDependency {
  fromStepType: String(this.length > 0)
  toStepType: String(this.length > 0)
  description: String(this.length > 0)
}

/// Process template consumed by trace planning.
class ProcessDefinition {
  processType: String(this.length > 0)
  steps: Listing<ProcessStep>
  dependencies: Listing<ProcessDependency>
}

/// Valid master-data combination and hard sampling guardrails.
class MasterDataEntry {
  materialId: String(this.length > 0)
  validVendors: Listing<String>
  validPlants: Listing<String>
  validPurchasingOrgs: Listing<String>
  validStorageLocations: Listing<String>
  quantityMin: Int(this >= 1)
  quantityMax: Int(this >= quantityMin)
  priceMin: Float(this > 0)
  priceMax: Float(this >= priceMin)
  currency: String(this.length > 0)
  deliveryLeadTimeMinDays: Int(this >= 0)
  deliveryLeadTimeMaxDays: Int(this >= deliveryLeadTimeMinDays)
}

/// SAP connection metadata. Contains env var names only.
class SapConfig {
  loginUrlEnvVar: String(this.length > 0)
}

/// Fraud scenario switch and target share placeholder.
class FraudScenario {
  id: String(this.length > 0)
  enabled: Boolean
  targetShare: Float(this >= 0 && this <= 1)
}

/// Top-level generation run settings.
class RunSettings {
  caseCount: Int(this >= 1)
  maxParallelActorSessions: Int(this >= 1)
  targetTimezone: String(this.length > 0)
  activeProcessTypes: Listing<String>
  schedulerSeed: Int = 1
  runStartDate: String(this.length > 0) = "2026-05-18"
  runHorizonDays: Int(this >= 1) = 30
  queuePolicy: String(this == "fifo") = "fifo"
  workingHours: WorkingHoursConfig = new WorkingHoursConfig {}
  stepDurationMinutes: Mapping<String, MinuteRange> = new Mapping {}
  interStepDelayMinutes: Listing<InterStepDelayRange> = new Listing {}
  storageLocationLabels: Mapping<String, String> = new Mapping {}
  postProcessingExportGroups: Listing<PostProcessingExportGroup> = new Listing {}
  realism: RealismCompilerSettings = new RealismCompilerSettings {}
}
