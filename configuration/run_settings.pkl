    pauseDurationMinutesMax = 75
  }
  stepDurationMinutes {
    ["create_purchase_requisition"] = new objects.MinuteRange {
      min = 8
      max = 14
    }
    ["create_purchase_order"] = new objects.MinuteRange {
      min = 7
      max = 12
    }
    ["post_goods_receipt"] = new objects.MinuteRange {
      min = 5
      max = 10
    }
    ["enter_incoming_invoice"] = new objects.MinuteRange {
      min = 8
      max = 15
    }
    ["post_outgoing_payment"] = new objects.MinuteRange {
      min = 5
      max = 10
    }
  }
  interStepDelayMinutes {
    new objects.InterStepDelayRange {
      fromStepType = "create_purchase_requisition"
