  activeProcessTypes {
    "procure_to_pay"
  }
  schedulerSeed = 42
  runStartDate = "2026-05-18"
  runHorizonDays = 30
  queuePolicy = "fifo"
  realism {
    enabled = true
    maxRetries = 3
