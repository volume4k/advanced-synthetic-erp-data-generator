      max = 180
    }
    new objects.InterStepDelayRange {
      fromStepType = "create_purchase_order"
      toStepType = "post_goods_receipt"
      min = 240
      max = 2880
    }
    new objects.InterStepDelayRange {
      fromStepType = "post_goods_receipt"
      toStepType = "enter_incoming_invoice"
      min = 120
      max = 1440
    }
    new objects.InterStepDelayRange {
      fromStepType = "enter_incoming_invoice"
      toStepType = "post_outgoing_payment"
      min = 240
      max = 2880
    }
  }
  storageLocationLabels {
    ["0001"] = "Finished Goods"
    ["0002"] = "Trading Goods"
  }
  postProcessingExportGroups {
    new objects.PostProcessingExportGroup {
      id = "change_documents"
      description =
        "SAP change document exports used for timestamp and object-change reconciliation."
    }
    new objects.PostProcessingExportGroup {
      id = "purchase_orders"
      description = "Purchase order exports used to correlate purchase order headers and items."
    }
    new objects.PostProcessingExportGroup {
      id = "material_documents"
      description = "Material document exports used to correlate goods receipts."
    }
    new objects.PostProcessingExportGroup {
      id = "supplier_invoices"
      description = "Supplier invoice exports used to correlate incoming invoices."
    }
    new objects.PostProcessingExportGroup {
      id = "accounting_documents"
