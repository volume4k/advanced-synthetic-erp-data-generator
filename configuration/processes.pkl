prToPoDependency: objects.ProcessDependency = new objects.ProcessDependency {
  fromStepType = "create_purchase_requisition"
  toStepType = "create_purchase_order"
  description =
    "Create purchase order after purchase requisition because A2 needs the purchase requisition number produced by A1."
}

prToPoWithAddressDependency: objects.ProcessDependency = new objects.ProcessDependency {
  fromStepType = "create_purchase_requisition"
  toStepType = "create_purchase_order_with_delivery_address"
  description =
    "Create purchase order with delivery address after purchase requisition because the order needs the purchase requisition number."
}

poToGoodsReceiptDependency: objects.ProcessDependency = new objects.ProcessDependency {
  fromStepType = "create_purchase_order"
  toStepType = "post_goods_receipt"
  description =
    "Post goods receipt after purchase order creation because A3 requires the purchase order created by A2."
}

poWithAddressToGoodsReceiptDependency: objects.ProcessDependency = new objects.ProcessDependency {
  fromStepType = "create_purchase_order_with_delivery_address"
  toStepType = "post_goods_receipt"
  description = "Post goods receipt after address-change purchase order creation."
}

poWithAddressToLarceny5GoodsReceiptDependency: objects.ProcessDependency = new objects
  .ProcessDependency {
  fromStepType = "create_purchase_order_with_delivery_address"
  toStepType = "post_larceny5_goods_receipt"
  description =
    "Post LARCENY5 goods receipt after the manipulated delivery-address purchase order exists."
}

larceny5GoodsReceiptToInvoiceDependency: objects.ProcessDependency = new objects.ProcessDependency {
  fromStepType = "post_larceny5_goods_receipt"
  toStepType = "enter_incoming_invoice"
  description = "Enter incoming invoice after the LARCENY5 goods receipt."
}

poToSplitGoodsReceiptDependency: objects.ProcessDependency = new objects.ProcessDependency {
  fromStepType = "create_purchase_order"
  toStepType = "post_split_goods_receipt"
  description = "Post split goods receipt after purchase order creation."
}

splitGoodsReceiptToScrapDependency: objects.ProcessDependency = new objects.ProcessDependency {
  fromStepType = "post_split_goods_receipt"
  toStepType = "scrap_quality_inspection_stock"
  description = "Scrap quality-inspection stock after split goods receipt creates it."
}

scrapToInvoiceDependency: objects.ProcessDependency = new objects.ProcessDependency {
  fromStepType = "scrap_quality_inspection_stock"
  toStepType = "enter_incoming_invoice"
  description = "Enter incoming invoice after the LARCENY3 quality-inspection stock movement."
}

splitGoodsReceiptToReleaseDependency: objects.ProcessDependency = new objects.ProcessDependency {
  fromStepType = "post_split_goods_receipt"
  toStepType = "release_quality_inspection_stock"
  description = "Release quality-inspection stock after routine split goods receipt creates it."
}

releaseToInvoiceDependency: objects.ProcessDependency = new objects.ProcessDependency {
  fromStepType = "release_quality_inspection_stock"
  toStepType = "enter_incoming_invoice"
  description = "Enter incoming invoice after quality-inspection stock release."
}

goodsReceiptToInvoiceDependency: objects.ProcessDependency = new objects.ProcessDependency {
  fromStepType = "post_goods_receipt"
  toStepType = "enter_incoming_invoice"
  description = "Enter incoming invoice after goods receipt in the version-one procure-to-pay flow."
}

invoiceToPaymentDependency: objects.ProcessDependency = new objects.ProcessDependency {
  fromStepType = "enter_incoming_invoice"
  toStepType = "post_outgoing_payment"
  description =
    "Post outgoing payment after incoming invoice entry because payment requires an invoice."
}

invoiceToBankChangeDependency: objects.ProcessDependency = new objects.ProcessDependency {
  fromStepType = "enter_incoming_invoice"
  toStepType = "change_vendor_bank_data"
  description = "Change vendor bank details after incoming invoice entry."
}

bankChangeToPaymentDependency: objects.ProcessDependency = new objects.ProcessDependency {
  fromStepType = "change_vendor_bank_data"
  toStepType = "post_outgoing_payment"
  description = "Post outgoing payment while manipulated vendor bank details are active."
}

paymentToBankRevertDependency: objects.ProcessDependency = new objects.ProcessDependency {
  fromStepType = "post_outgoing_payment"
  toStepType = "revert_vendor_bank_data"
  description = "Revert vendor bank details after outgoing payment."
}

procureToPayProcess: objects.ProcessDefinition = new objects.ProcessDefinition {
  processType = "procure_to_pay"
  scenarioType = "NORMAL"
  steps {
    createPurchaseRequisitionStep
    createPurchaseOrderStep
    postGoodsReceiptStep
    enterIncomingInvoiceStep
    postOutgoingPaymentStep
  }
  dependencies {
    prToPoDependency
    poToGoodsReceiptDependency
    goodsReceiptToInvoiceDependency
    invoiceToPaymentDependency
  }
}

vendorFlipflopProcureToPayProcess: objects.ProcessDefinition = new objects.ProcessDefinition {
  processType = "procure_to_pay"
  scenarioType = "VENDOR_FLIPFLOP"
  steps {
    createPurchaseRequisitionStep
    createPurchaseOrderStep
    postGoodsReceiptStep
    enterIncomingInvoiceStep
    changeVendorBankDataStep
    postOutgoingPaymentStep
    revertVendorBankDataStep
  }
  dependencies {
    prToPoDependency
    poToGoodsReceiptDependency
    goodsReceiptToInvoiceDependency
    invoiceToBankChangeDependency
    bankChangeToPaymentDependency
    paymentToBankRevertDependency
  }
}

larceny3ProcureToPayProcess: objects.ProcessDefinition = new objects.ProcessDefinition {
  processType = "procure_to_pay"
