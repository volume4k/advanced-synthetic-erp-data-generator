processes: Listing<objects.ProcessDefinition> = new Listing {
  procureToPayProcess
  vendorFlipflopProcureToPayProcess
  larceny3ProcureToPayProcess
  larceny5ProcureToPayProcess
  routineAddressChangeProcureToPayProcess
  routineQualityInspectionProcureToPayProcess
  routineVendorBankChangeProcureToPayProcess
