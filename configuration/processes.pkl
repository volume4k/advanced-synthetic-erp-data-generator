import "fraud_scenarios.pkl" as fraudConfig
import "generated_tool_config.pkl"
import "objects.pkl"

toolRequirements = generated_tool_config.toolRequirements
vendorFlipflop = fraudConfig.vendorFlipflopConfig
routineVendorBankAccount = fraudConfig.routineVendorBankAccount

createPurchaseRequisitionStep: objects.ProcessStep = new objects.ProcessStep {
  stepId = "A1"
  stepType = "create_purchase_requisition"
  tool = toolRequirements["fiori.create_purchase_requisition"]
  inputBindings {
    new objects.ToolInputBinding {
      field = "material"
      source = "master_data"
      value = "materialId"
    }
    new objects.ToolInputBinding {
      field = "quantity"
      source = "case"
      value = "quantity"
    }
    new objects.ToolInputBinding {
      field = "valuation_price"
      source = "case"
      value = "target_price"
    }
    new objects.ToolInputBinding {
      field = "currency"
      source = "master_data"
      value = "currency"
    }
    new objects.ToolInputBinding {
      field = "price_unit"
      source = "literal"
      value = "1"
      valueType = "int"
    }
    new objects.ToolInputBinding {
      field = "delivery_date"
      source = "derived"
      value = "fiori_delivery_date"
    }
    new objects.ToolInputBinding {
      field = "plant"
      source = "master_data"
      value = "plant"
    }
    new objects.ToolInputBinding {
      field = "purchasing_group"
      source = "literal"
      value = "N00"
    }
    new objects.ToolInputBinding {
      field = "purchasing_organization"
      source = "master_data"
      value = "purchasing_org"
    }
    new objects.ToolInputBinding {
      field = "company_code"
      source = "master_data"
      value = "purchasing_org"
    }
  }
  plannedDateInputBindings {
    new objects.ToolInputBinding {
      field = "delivery_date"
      source = "derived"
      value = "fiori_delivery_date"
    }
  }
  requiredSapObjectKeys {
    "purchase_requisition.pr_number"
  }
}

createPurchaseOrderStep: objects.ProcessStep = new objects.ProcessStep {
  stepId = "A2"
  stepType = "create_purchase_order"
  tool = toolRequirements["fiori.create_purchase_order"]
  inputBindings {
    new objects.ToolInputBinding {
      field = "purchase_requisition"
      source = "prior_output"
      value = "purchase_requisition.pr_number"
    }
    new objects.ToolInputBinding {
      field = "storage_location"
      source = "case"
      value = "storage_location"
    }
    new objects.ToolInputBinding {
      field = "supplier"
      source = "master_data"
      value = "vendor_id"
    }
    new objects.ToolInputBinding {
      field = "quantity"
      source = "case"
      value = "quantity"
    }
    new objects.ToolInputBinding {
      field = "net_price"
      source = "case"
      value = "target_price"
    }
  }
  requiredSapObjectKeys {
    "purchase_order.po_number"
  }
}

