scrapQualityInspectionStockStep: objects.ProcessStep = new objects.ProcessStep {
  stepId = "Q2"
  stepType = "scrap_quality_inspection_stock"
  tool = toolRequirements["fiori.manage_quality_inspection_stock"]
  inputBindings {
    new objects.ToolInputBinding {
      field = "material"
      source = "case"
      value = "material_id"
    }
    new objects.ToolInputBinding {
      field = "stock_location_label"
      source = "literal"
      value = "DC Miami"
    }
    new objects.ToolInputBinding {
      field = "movement"
      source = "literal"
      value = "scrap"
    }
    new objects.ToolInputBinding {
      field = "quantity"
      source = "derived"
      value = "quality_inspection_quantity"
    }
    new objects.ToolInputBinding {
      field = "document_item_text"
      source = "literal"
      value = "Muss leider verschrottet werden."
    }
    new objects.ToolInputBinding {
      field = "cost_center"
      source = "literal"
      value = "NAPC1000"
    }
  }
  plannedDateInputBindings {
    new objects.ToolInputBinding {
      field = "posting_date"
      source = "derived"
      value = "fiori_delivery_date"
    }
  }
  requiredSapObjectKeys {
    "scrap_material_document.material_document_number"
  }
}

