import "generated_tool_config.pkl"
import "tool_config_schema.pkl"

toolRequirements = generated_tool_config.toolRequirements

procureToPayProcess: tool_config_schema.ProcureToPayProcess = new tool_config_schema
  .ProcureToPayProcess {
  processType = "procure_to_pay"

  steps {
    new tool_config_schema.ProcessStep {
      stepId = "A1"
      stepType = "create_purchase_requisition"
      tool = toolRequirements["fiori.create_purchase_requisition"]
      requiredRole = "procurement"
    }
    new tool_config_schema.ProcessStep {
      stepId = "A2"
      stepType = "create_purchase_order"
      tool = toolRequirements["fiori.create_purchase_order"]
      requiredRole = "procurement"
    }
    new tool_config_schema.ProcessStep {
      stepId = "A3"
      stepType = "release_purchase_order"
      tool = null
      requiredRole = "procurement_manager"
    }
    new tool_config_schema.ProcessStep {
      stepId = "A4"
      stepType = "post_goods_receipt"
      tool = null
      requiredRole = "warehouse"
    }
    new tool_config_schema.ProcessStep {
      stepId = "A5"
      stepType = "enter_incoming_invoice"
      tool = null
      requiredRole = "accounts_payable"
    }
    new tool_config_schema.ProcessStep {
      stepId = "A6"
      stepType = "post_outgoing_payment"
      tool = null
      requiredRole = "accounts_payable"
    }
  }

  dependencies {
    // A2 needs the purchase requisition number produced by A1.
    new tool_config_schema.ProcessDependency {
      fromStepId = "A1"
      toStepId = "A2"
      description =
        "Create purchase order after purchase requisition because A2 needs the purchase requisition number produced by A1."
    }
    // A3 can only release a purchase order that already exists.
    new tool_config_schema.ProcessDependency {
      fromStepId = "A2"
      toStepId = "A3"
      description =
        "Release purchase order after creation because A3 needs the purchase order created by A2."
    }
    // A4 posts receipt against a released purchase order.
    new tool_config_schema.ProcessDependency {
      fromStepId = "A3"
      toStepId = "A4"
      description =
        "Post goods receipt after release because A4 requires a released purchase order."
    }
    // A5 follows goods receipt in the version-one single-line P2P flow.
    new tool_config_schema.ProcessDependency {
      fromStepId = "A4"
      toStepId = "A5"
      description =
        "Enter incoming invoice after goods receipt in the version-one procure-to-pay flow."
    }
    // A6 pays only after invoice entry.
    new tool_config_schema.ProcessDependency {
      fromStepId = "A5"
      toStepId = "A6"
      description =
        "Post outgoing payment after incoming invoice entry because payment requires an invoice."
    }
  }
}
